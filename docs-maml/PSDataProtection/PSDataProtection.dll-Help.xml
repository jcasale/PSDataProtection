    </command:relatedLinks>
  </command:command>
  <command:command>
    <command:details>
      <command:name>Read-DataProtectionSecret</command:name>
      <maml:description>
        <maml:para>Reads the unencrypted value of a secret that was encrypted with data protection.</maml:para>
      </maml:description>
      <command:verb>Read</command:verb>
      <command:noun>DataProtectionSecret</command:noun>
    </command:details>
    <maml:description>
      <maml:para>The Read-DataProtectionSecret cmdlet decrypts a secret that was previously encrypted with data protection.</maml:para>
    </maml:description>
